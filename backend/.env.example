# ============================================================
# AI 量化研究员 — 大模型(LLM) 配置
# 复制为 .env 并填入你的密钥即可激活「真实大模型」生成。
# 未配置 LLM_API_KEY 时，系统自动使用规则合成（页面会标注「规则合成」）。
# ============================================================

# 是否启用：留空或删除则自动判定为未启用
LLM_API_KEY=

# OpenAI 兼容接口的 Base URL（注意去掉末尾的 /v1 之外的多余路径）
#  - OpenAI:      https://api.openai.com/v1
#  - DeepSeek:    https://api.deepseek.com/v1
#  - 通义千问:     https://dashscope.aliyuncs.com/compatible-mode/v1
#  - 文心一言:     https://qianfan.baidubce.com/v2  (需使用推理接入点模型名)
LLM_BASE_URL=https://api.openai.com/v1

# 模型名（按对应平台填写）
#  - OpenAI:   gpt-4o-mini / gpt-4o
#  - DeepSeek: deepseek-chat / deepseek-reasoner
#  - 通义千问:  qwen-plus / qwen-max / qwen-turbo
LLM_MODEL=gpt-4o-mini

# 单次调用超时（秒）与最大输出 token
LLM_TIMEOUT=60
LLM_MAX_TOKENS=1500

# 真实行情数据缓存 TTL（秒）
DATA_CACHE_TTL=30

# ============================================================
# 持久化数据库 + WebSocket 实时推送
# ============================================================
# 数据库连接串（SQLAlchemy）。同一套 ORM 代码兼容 SQLite 与 PostgreSQL。
#  - 本地/沙箱验证（默认）: sqlite:///./quant.db
#  - 生产 PostgreSQL（需先 pip install "psycopg[binary]"）:
#      postgresql+psycopg://user:pass@localhost:5432/quantdb
# 也可一键起库：docker compose up -d postgres
DATABASE_URL=sqlite:///./quant.db

# WebSocket 实时行情推送间隔（秒）
WS_PUSH_INTERVAL=5
