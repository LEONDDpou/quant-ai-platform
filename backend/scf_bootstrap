#!/bin/bash
# ============================================================
# Tencent Cloud SCF Web Function 启动脚本
# 首次冷启动时下载 Node.js（约 35MB），后续复用实例缓存
# ============================================================
set -e

# 1. 确保 Node.js 可用（供 westock 取数脚本使用）
export NODE_BIN=/tmp/node/bin/node
if [ ! -f "$NODE_BIN" ]; then
  echo "[bootstrap] 首次冷启动，下载 Node.js..."
  mkdir -p /tmp/node
  curl -sL "https://nodejs.org/dist/v22.0.0/node-v22.0.0-linux-x64.tar.xz" | tar -xJ -C /tmp/node --strip-components=1
  echo "[bootstrap] Node.js 就绪: $($NODE_BIN --version)"
fi

# 2. 环境变量
export WESTOCK_SCRIPT=/var/user/westock/index.js
export NODE_BIN
export CORS_ALLOW_ORIGINS="*"
export PYTHONUNBUFFERED=1

# 3. 启动 uvicorn（监听 SCF 指定的端口）
cd /var/user
exec python3 -m uvicorn app.main:app --host 0.0.0.0 --port 9000
