# ============================================================
# quant-ai-platform — Docker 部署环境变量示例
# 用法：复制为项目根目录的 .env 后填入真实值（compose 自动加载）
#   cp .env.example .env
# ============================================================

# —— AI 研究员 LLM 配置（deepseek / 通义 / 文心 / OpenAI 兼容）——
LLM_API_KEY=sk-your-real-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# 说明：
#   - DATABASE_URL 已在 docker-compose.yml 中指向 Postgres 服务，无需在此设置
#   - CORS_ALLOW_ORIGINS 默认 "*"（开发/演示）；生产改成你的前端域名逗号分隔
#   - WESTOCK_SCRIPT / NODE_BIN 容器内已固定，无需设置
